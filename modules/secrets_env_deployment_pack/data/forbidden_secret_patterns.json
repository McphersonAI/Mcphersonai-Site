{
  "version": "1.0",
  "description": "Regex patterns for obvious secret-like strings. Lines containing an allowlisted placeholder substring are skipped.",
  "patterns": [
    {"name": "aws_access_key", "regex": "AKIA[0-9A-Z]{16}"},
    {"name": "openai_or_anthropic_style_key", "regex": "sk-[A-Za-z0-9_-]{20,}"},
    {"name": "github_token", "regex": "gh[pousr]_[A-Za-z0-9]{36}"},
    {"name": "slack_token", "regex": "xox[baprs]-[A-Za-z0-9-]{10,}"},
    {"name": "stripe_key", "regex": "(sk|pk|rk)_(live|test)_[A-Za-z0-9]{16,}"},
    {"name": "telegram_bot_token", "regex": "[0-9]{8,10}:[A-Za-z0-9_-]{35}"},
    {"name": "langfuse_key", "regex": "(sk|pk)-lf-[A-Za-z0-9-]{20,}"},
    {"name": "private_key_block", "regex": "-----BEGIN [A-Z ]*PRIVATE KEY-----"},
    {"name": "bearer_token", "regex": "Bearer [A-Za-z0-9._=-]{25,}"},
    {"name": "jwt_like_token", "regex": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{5,}"},
    {"name": "password_assignment", "regex": "(?i)(password|passwd|pwd)\\s*[=:]\\s*[\"'][^\"']{8,}[\"']"}
  ],
  "placeholder_allowlist": ["__PLACEHOLDER_DO_NOT_USE__", "REPLACE_ME", "fake_", "sample_", "SAMPLE ONLY", "FICTIONAL"],
  "scan_exempt_files": ["data/forbidden_secret_patterns.json", "scripts/scan_for_secret_patterns.py", "tests/test_forbidden_secret_patterns.py", "tests/test_no_real_secrets_or_client_data.py"],
  "scan_ignore_directories": [".git", ".pytest_cache", "__pycache__", "node_modules", "dist", "exports"],
  "text_extensions": [".md", ".py", ".json", ".txt", ".yml", ".yaml", ".toml", ".cfg", ".ini", ".sh", ".example"]
}

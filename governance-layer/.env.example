TELEGRAM_ENABLED=false
HUMAN_ONLY_MODE=true
ALLOW_SQLITE_WRITES=false
ALLOW_TOOL_EXECUTION=false
ALLOW_OUTBOUND_ACTIONS=false
LANGFUSE_ENABLED=true
LANGFUSE_MODE=metadata_only
SANITIZED_CONTENT=false
